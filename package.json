{
  "name": "desktop-buddy",
  "version": "1.0.0",
  "description": "Desktop buddy widget - looping video with chroma key and mask",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.desktopbuddy.app",
    "productName": "Desktop Buddy",
    "win": {
      "target": "nsis",
      "icon": null
    },
    "files": [
      "main.js",
      "preload.js",
      "controls-preload.js",
      "index.html",
      "controls.html"
    ],
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "fileAssociations": [
      {
        "ext": "buddy",
        "name": "Desktop Buddy File",
        "description": "Desktop Buddy configuration",
        "role": "Viewer"
      }
    ]
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  }
}
